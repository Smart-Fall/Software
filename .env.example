# ============================================================================
# Database Configuration
# ============================================================================

# Database Provider: "prisma" | "convex"
# Default: "prisma"
# Controls which database backend is used
DATABASE_PROVIDER="prisma"

# PostgreSQL Configuration (required if DATABASE_PROVIDER="prisma")
DATABASE_URL="postgresql://postgres:CEG4912@localhost:5432/smartfall_db"

# Convex Configuration (required if DATABASE_PROVIDER="convex")
# Get these from https://dashboard.convex.dev
CONVEX_DEPLOYMENT=""  # e.g., "dev:happy-panda-123"
NEXT_PUBLIC_CONVEX_URL=""  # e.g., "https://happy-panda-123.convex.cloud"

# ============================================================================
# Authentication
# ============================================================================

# JWT Secret (change this in production!)
JWT_SECRET="smartfallCapstone"

# Shared secret used by device firmware to authenticate fall ingestion requests.
# Must match DEVICE_API_KEY in Hardware/SmartFall/Config.h.
DEVICE_INGEST_API_KEY=""

# ============================================================================
# Environment
# ============================================================================

# Node Environment: "development" | "production"
NODE_ENV="development"

# ============================================================================
# CORS Configuration
# ============================================================================

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
