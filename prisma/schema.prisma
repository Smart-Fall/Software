// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.Text
  accountType  String    @map("account_type") @db.VarChar(50)
  firstName    String?   @map("first_name") @db.VarChar(255)
  lastName     String?   @map("last_name") @db.VarChar(255)
  dob          DateTime? @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  sessions  Session[]
  patient   Patient?
  caregiver Caregiver?

  @@map("users")
}

model Session {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  sessionToken String    @unique @map("session_token") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  expiresAt    DateTime? @map("expires_at") @db.Timestamp(6)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Patient {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  riskScore         Int      @default(0) @map("risk_score")
  isHighRisk        Boolean  @default(false) @map("is_high_risk")
  medicalConditions String?  @map("medical_conditions") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  falls             Fall[]
  caregiverPatients CaregiverPatient[]
  devices           Device[]
  healthLogs        HealthLog[]

  @@map("patients")
}

model HealthLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  healthScore Int      @map("health_score")
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamp(6)

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, recordedAt])
  @@map("health_logs")
}

model Caregiver {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  facilityName      String?  @map("facility_name") @db.VarChar(255)
  specialization    String?  @db.VarChar(255)
  yearsOfExperience Int?     @map("years_of_experience")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  caregiverPatients CaregiverPatient[]

  @@map("caregivers")
}

model CaregiverPatient {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caregiverId  String   @map("caregiver_id") @db.Uuid
  patientId    String   @map("patient_id") @db.Uuid
  assignedDate DateTime @default(now()) @map("assigned_date") @db.Timestamp(6)
  isActive     Boolean  @default(true) @map("is_active")

  caregiver Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([caregiverId, patientId])
  @@map("caregiver_patients")
}

model Fall {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId       String?   @map("patient_id") @db.Uuid
  deviceId        String?   @map("device_id") @db.Uuid
  fallDatetime    DateTime  @map("fall_datetime") @db.Timestamp(6)
  confidenceScore Int?      @map("confidence_score")
  confidenceLevel String?   @map("confidence_level") @db.VarChar(50)
  sosTriggered    Boolean   @default(false) @map("sos_triggered")
  severity        String?   @db.VarChar(50)
  location        String?   @db.VarChar(255)
  wasInjured      Boolean?  @map("was_injured")
  notes           String?   @db.Text
  batteryLevel    Float?    @map("battery_level")
  resolved        Boolean   @default(false)
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamp(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
  device  Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@map("falls")
}

model Device {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId        String    @unique @map("device_id") @db.VarChar(32)
  patientId       String?   @map("patient_id") @db.Uuid
  deviceName      String?   @map("device_name") @db.VarChar(100)
  isActive        Boolean   @default(true) @map("is_active")
  lastSeen        DateTime? @map("last_seen") @db.Timestamp(6)
  batteryLevel    Float?    @map("battery_level")
  firmwareVersion String?   @map("firmware_version") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  patient       Patient?       @relation(fields: [patientId], references: [id], onDelete: SetNull)
  falls         Fall[]
  sensorData    SensorData[]
  statusUpdates DeviceStatus[]

  @@map("devices")
}

model SensorData {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId  String   @map("device_id") @db.Uuid
  timestamp DateTime @default(now()) @db.Timestamp(6)
  accelX    Float    @map("accel_x")
  accelY    Float    @map("accel_y")
  accelZ    Float    @map("accel_z")
  gyroX     Float    @map("gyro_x")
  gyroY     Float    @map("gyro_y")
  gyroZ     Float    @map("gyro_z")
  pressure  Float?
  fsr       Float?   @map("fsr")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
  @@map("sensor_data")
}

model DeviceStatus {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId           String   @map("device_id") @db.Uuid
  timestamp          DateTime @default(now()) @db.Timestamp(6)
  batteryPercentage  Float    @map("battery_percentage")
  wifiConnected      Boolean  @map("wifi_connected")
  bluetoothConnected Boolean  @map("bluetooth_connected")
  sensorsInitialized Boolean  @map("sensors_initialized")
  uptimeMs           BigInt   @map("uptime_ms")
  currentStatus      String?  @map("current_status") @db.VarChar(100)

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
  @@map("device_status")
}
